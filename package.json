{
  "name": "motion-recipes-remotion",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://chibataku0815.github.io/motion-recipes-remotion/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chibataku0815/motion-recipes-remotion.git"
  },
  "bugs": {
    "url": "https://github.com/chibataku0815/motion-recipes-remotion/issues"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "remotion studio",
    "pages:dev": "vite --config vite.config.ts",
    "pages:build": "vite build --config vite.config.ts",
    "pages:preview": "vite preview --config vite.config.ts",
    "render:44": "remotion render src/index.ts EchoDitherTrail media/echo-dither-trail/44-preview.mp4 --gl=angle",
    "render:45": "remotion render src/index.ts TrimPathsRadialBurst media/trim-paths-radial-burst/45-preview.mp4 --gl=angle",
    "render:46": "remotion render src/index.ts AETipOverlayGradientBackground media/overlay-gradient-background/46-preview.mp4 --gl=angle",
    "render:48": "remotion render src/index.ts OverlayRingTitleMinimal media/overlay-ring-title-minimal/48-preview.mp4 --gl=angle",
    "render:49": "remotion render src/index.ts AETipNowLoadingProgressBar media/now-loading-progress-bar/49-preview.mp4 --gl=angle",
    "render:50": "remotion render src/index.ts OverlayRingTitleAccentBurst media/overlay-ring-title-accent-burst/50-preview.mp4 --gl=angle",
    "render:56": "remotion render src/index.ts AETipEchoTextTrain media/echo-text-train/56-preview.mp4 --gl=angle",
    "render:57": "remotion render src/index.ts AETipTextPathMorphing media/text-path-morphing/57-preview.mp4 --gl=angle"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/themes": "^3.3.0",
    "@remotion/cli": "4.0.441",
    "flubber": "^0.4.2",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "remotion": "4.0.441"
  },
  "devDependencies": {
    "@types/flubber": "^0.4.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
}
